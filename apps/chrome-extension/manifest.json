{
  "manifest_version": 3,
  "name": "bkmr 书签",
  "version": "1.0.0",
  "description": "通过 bkmr-desktop 快速添加当前页面为书签",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "添加到 bkmr"
  },
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:8733/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
